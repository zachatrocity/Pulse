NODE_ENV=development
PULSE_HOST=0.0.0.0
PULSE_PORT=8787
PULSE_PUBLIC_URL=http://127.0.0.1:8787
PULSE_WEB_ORIGIN=http://localhost:5173
PULSE_DATA_DIR=./data
PULSE_SESSION_SECRET=change-me-to-at-least-32-characters
PULSE_OAUTH_SCOPE=atproto repo:app.pulse.room repo:app.pulse.room.server repo:app.pulse.room.member repo:app.pulse.room.presence
# Required when PULSE_PUBLIC_URL is not local loopback, especially in production.
# Generate with: npm run gen:oauth-key
PULSE_OAUTH_PRIVATE_KEY=
PULSE_DATABASE_PATH=./data/pulse.sqlite
PULSE_ATPROTO_PDS_URL=https://bsky.social
PULSE_INDEXER_REPOS=
PULSE_INDEXER_JETSTREAM_URL=
